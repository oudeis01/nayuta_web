# deploy.env — config for scripts/deploy_pages.sh. Copy to deploy.env (gitignored)
# and fill in. Plain KEY=value, shell-sourced (no spaces around =, no `export`).

# Heavy assets live on R2; these are the public base URLs the built site fetches.
# Use the bucket's public r2.dev URL or your custom domain (no trailing slash).
VITE_CAPTURE_BASE=https://<r2-public-host>/captures
VITE_AUDIO_BASE=https://<r2-public-host>/audio

# Existing Cloudflare Pages project name (create once:
#   wrangler pages project create <name>
# ). This is NOT the R2 bucket name — separate namespaces.
CF_PAGES_PROJECT=<pages-project-name>

# Optional: deploy branch. Your project's production branch publishes to prod;
# any other name makes a preview deployment. Leave unset to let wrangler decide.
#CF_PAGES_BRANCH=main
